NODE_ENV=development
HOST=0.0.0.0
PORT=8000

# MongoDB Atlas or local
MONGODB_URI=mongodb://localhost:27017/event_management

# Base64-encoded PEM key bodies (copy from product-farming/server/.env)
PUBLIC_KEY=
PRIVATE_KEY=

# Comma-separated allowed browser origins (credentials required for auth cookies)
CORS_ORIGINS=http://localhost:3000,https://events.orbitalops.net

PASSWORD_MIN_LENGTH=8
SEED_ADMIN_EMAIL=admin@orbitalops.net
SEED_ADMIN_PASSWORD=EventAdmin@123

# Cloudinary (speaker photos) — copy from product-farming/server/.env
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Gemini (AI event content) — get a key from https://aistudio.google.com/apikey
# Must start with AIza... (Google AI Studio API key)
GEMINI_API_KEY=

# GraphiQL UI at /graphql (enabled by default; set to false for API-only)
GRAPHIQL_ENABLED=true

# Quick check: npm run validate:env
